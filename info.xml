<?xml version="1.0"?>
<extension key="com.joineryhq.relationshipjobtitle" type="module">
  <file>relationshipjobtitle</file>
  <name>Relationship Job Title</name>
  <description>On the Contact Relationships tab, display the contact's Job Title together with the current employer.</description>
  <license>GPL-3.0</license>
  <maintainer>
    <author>Allen Shaw</author>
    <email>allen@JoineryHQ.com</email>
  </maintainer>
  <releaseDate>2022-09-23</releaseDate>
  <version>2.4.0</version>
  <develStage>stable</develStage>
  <compatibility>
    <ver>5.51</ver>
  </compatibility>
  <comments/>
  <urls>
    <url desc="Main extension page and bare-bones documentation">https://github.com/twomice/com.joineryhq.relationshipjobtitle</url>
    <url desc="Support">https://github.com/twomice/com.joineryhq.relationshipjobtitle/issues</url>
  </urls>
  <civix>
    <namespace>CRM/Relationshipjobtitle</namespace>
    <format>25.10.2</format>
  </civix>
  <classloader>
    <psr4 prefix="Civi\" path="Civi"/>
  </classloader>
  <mixins>
    <mixin>entity-types-php@2.0.0</mixin>
    <mixin>scan-classes@1.0.0</mixin>
  </mixins>
</extension>
